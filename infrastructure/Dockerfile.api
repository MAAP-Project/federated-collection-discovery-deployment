ARG PYTHON_VERSION=3.12

FROM --platform=linux/amd64 public.ecr.aws/lambda/python:${PYTHON_VERSION}
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /tmp
ARG API_VERSION=v0.3.0
RUN dnf install -y git
RUN uv pip install git+https://github.com/developmentseed/stac-fastapi-collection-discovery@${API_VERSION}[lambda] \
  --compile-bytecode --no-binary pydantic --target /asset

CMD ["echo", "hello world"]

